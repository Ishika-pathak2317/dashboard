# .env — copy this to .env and fill in your values
# NEVER commit .env to git

# ── Database ──────────────────────────────────────────────────
# SQLite (default, no setup needed):
DATABASE_URL=sqlite:///./dashboard.db

# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://username:password@localhost:5432/analytics_db

# MySQL:
# DATABASE_URL=mysql+pymysql://username:password@localhost:3306/analytics_db

# ── Flask ─────────────────────────────────────────────────────
FLASK_ENV=development   # change to 'production' on server
SECRET_KEY=change-me-to-a-random-string-in-production
PORT=5000
